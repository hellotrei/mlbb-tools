# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mlbb_tools

# Redis
REDIS_URL=redis://localhost:6379

# Service ports
WEB_PORT=5173
API_PORT=8787

# GMS API
GMS_API_KEY=
GMS_SOURCE_BASE_URL=https://api.gms.moontontech.com/api/gms/source
GMS_SOURCE_ID=2669606
GMS_META_ENDPOINT=2756564
GMS_LANG=en
GMS_META_PAGE_SIZE=100
GMS_STATS_ENDPOINT_1D=2756567
GMS_STATS_ENDPOINT_3D=2756568
GMS_STATS_ENDPOINT_7D=2756569
GMS_STATS_ENDPOINT_15D=2756565
GMS_STATS_ENDPOINT_30D=2756570
GMS_STATS_PAGE_SIZE=500
GMS_STATS_FILTER_MATCH_TYPE=0
GMS_STATS_FILTER_CAMP_TYPE=0

# Hero metadata source: gms
HERO_META_SOURCE=gms

# Worker schedule
INGEST_CRON=*/30 * * * *

# Supabase community counters
SUPABASE_URL=
SUPABASE_ANON_KEY=
COUNTERS_BLEND_WEIGHTS=community=55%,counter=25%,tier=20%
COUNTERS_BLEND_SOURCES=community,counter,tier
COUNTERS_COVERAGE_MULT_MIN=0.85
DRAFT_COUNTER_LANE_SATURATION_PENALTY_MAX=18%
DRAFT_COUNTER_FLEX_EARLY_BONUS=10%
DRAFT_COUNTER_FLEX_MID_BONUS=6%
DRAFT_COUNTER_UNCERTAINTY_MAX=35%
DRAFT_COUNTER_COMMUNITY_DAMPING_MIN=45%
DRAFT_COUNTER_COMMUNITY_VOTE_REF=250
DRAFT_COUNTER_DIVERSITY_ROLE_PENALTY=6%
DRAFT_COUNTER_DIVERSITY_ARCHETYPE_PENALTY=4%
DRAFT_COUNTER_DIVERSITY_LANE_PENALTY=5%
DRAFT_COUNTER_DIVERSITY_FLOOR=35%
