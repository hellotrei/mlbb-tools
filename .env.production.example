# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=mlbb_tools
DATABASE_URL=postgresql://postgres:replace_with_strong_password@mlbb-postgres:5432/mlbb_tools
DATABASE_POOL_MAX=10

# Redis — use container name (all services joined to mlbb_net)
# REDIS_PASSWORD is used by docker-compose.shared.yml to set requirepass on the Redis container.
# REDIS_URL must include the same password so API and worker can authenticate.
REDIS_PASSWORD=replace_with_strong_password
REDIS_URL=redis://:replace_with_strong_password@mlbb-redis:6379

# Ports
API_PORT=8787
WEB_PORT=3000
CORS_ORIGINS=https://mlbb-tools.example.com

# GMS API
GMS_API_KEY=
GMS_SOURCE_BASE_URL=https://api.gms.moontontech.com/api/gms/source
GMS_SOURCE_ID=2669606
GMS_META_ENDPOINT=2756564
GMS_LANG=en
GMS_META_PAGE_SIZE=100
GMS_STATS_ENDPOINT_1D=2756567
GMS_STATS_ENDPOINT_3D=2756568
GMS_STATS_ENDPOINT_7D=2756569
GMS_STATS_ENDPOINT_15D=2756565
GMS_STATS_ENDPOINT_30D=2756570
GMS_STATS_PAGE_SIZE=500
GMS_STATS_FILTER_MATCH_TYPE=0
GMS_STATS_FILTER_CAMP_TYPE=0

# Worker
INGEST_CRON=*/30 * * * *
ACTIVE_TIMEFRAMES=7d,15d,30d

# Optional community counters
SUPABASE_URL=
SUPABASE_ANON_KEY=
COUNTERS_BLEND_WEIGHTS=community=55%,counter=25%,tier=20%
COUNTERS_BLEND_SOURCES=community,counter,tier
COUNTERS_COVERAGE_MULT_MIN=0.85
