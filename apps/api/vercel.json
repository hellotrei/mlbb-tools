{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "cd ../.. && pnpm --filter @mlbb/api build",
  "installCommand": "cd ../.. && pnpm install --filter @mlbb/api... --frozen-lockfile --config.workspace-concurrency=1 --child-concurrency=1 --network-concurrency=1",
  "framework": null,
  "outputDirectory": ".",
  "functions": {
    "api/telegram-webhook.ts": {
      "maxDuration": 15
    },
    "api/index.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/telegram/webhook",
      "destination": "/api/telegram-webhook"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
