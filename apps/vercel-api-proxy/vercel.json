{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "cd ../.. && pnpm --filter @mlbb/vercel-api-proxy build",
  "installCommand": "cd ../.. && pnpm install --filter @mlbb/vercel-api-proxy... --frozen-lockfile",
  "framework": null,
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
