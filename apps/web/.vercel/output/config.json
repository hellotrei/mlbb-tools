{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/api(/[^]*)?/?(?:/__data.json)?$",
			"dest": "/api/[...path]"
		},
		{
			"src": "^/counter-pick/?(?:/__data.json)?$",
			"dest": "/counter-pick"
		},
		{
			"src": "^/draft-master/?(?:/__data.json)?$",
			"dest": "/draft-master"
		},
		{
			"src": "^/hero-statistics/?(?:/__data.json)?$",
			"dest": "/hero-statistics"
		},
		{
			"src": "^/hero-tier/?(?:/__data.json)?$",
			"dest": "/hero-tier"
		},
		{
			"src": "^/tournaments/?(?:/__data.json)?$",
			"dest": "/tournaments"
		},
		{
			"src": "^/tournaments/tutorial/?(?:/__data.json)?$",
			"dest": "/tournaments/tutorial"
		},
		{
			"src": "^/tournaments/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/tournaments/[id]"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}