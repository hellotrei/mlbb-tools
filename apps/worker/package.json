{
  "name": "@mlbb/worker",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "build": "pnpm --filter @mlbb/shared build && pnpm --filter @mlbb/db build && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint placeholder @mlbb/worker'",
    "test": "tsx --test src/*.test.ts src/**/*.test.ts"
  },
  "dependencies": {
    "@mlbb/db": "workspace:*",
    "@mlbb/shared": "workspace:*",
    "bullmq": "^5.34.6",
    "ioredis": "^5.3.2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
