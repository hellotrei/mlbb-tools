FROM node:20-alpine AS builder

WORKDIR /app
COPY . .

RUN corepack enable \
  && pnpm install --frozen-lockfile \
  && pnpm --filter @mlbb/shared build \
  && SVELTEKIT_ADAPTER=node pnpm --filter @mlbb/web build

FROM node:20-alpine
WORKDIR /app

COPY --from=builder /app .

ENV NODE_ENV=production
EXPOSE 3000

CMD ["node", "apps/web/build/index.js"]
