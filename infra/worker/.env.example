# ── Database ──────────────────────────────────────────────────────────────────
# Full Postgres connection string (same DB used by the API on the main VPS)
DATABASE_URL=postgresql://postgres:password@<MAIN_VPS_IP>:5432/mlbb_tools
DATABASE_POOL_MAX=5

# ── Redis (BullMQ) ────────────────────────────────────────────────────────────
# Must be the same Redis instance the API reads cache from
REDIS_URL=redis://<MAIN_VPS_IP>:6379

# ── Worker schedule ───────────────────────────────────────────────────────────
# Cron expression for periodic ingest + compute cycle (default: every 30 min)
INGEST_CRON=*/30 * * * *

# Comma-separated timeframes to process (default: 7d,15d,30d)
# Valid values: 1d, 3d, 7d, 15d, 30d
ACTIVE_TIMEFRAMES=7d,15d,30d

# ── Hero metadata source ──────────────────────────────────────────────────────
# "gms" fetches from the GMS API; "file" uses data/hero-meta-final.json only
HERO_META_SOURCE=gms

# ── GMS API ───────────────────────────────────────────────────────────────────
GMS_SOURCE_BASE_URL=https://api.gms.moontontech.com/api/gms/source
GMS_SOURCE_ID=2669606
# Bearer token; leave blank if the endpoint is public
GMS_API_KEY=
GMS_LANG=en

# Stats endpoint IDs per timeframe
GMS_STATS_ENDPOINT_1D=2756567
GMS_STATS_ENDPOINT_3D=2756568
GMS_STATS_ENDPOINT_7D=2756569
GMS_STATS_ENDPOINT_15D=2756565
GMS_STATS_ENDPOINT_30D=2756570
GMS_STATS_PAGE_SIZE=500
GMS_STATS_FILTER_MATCH_TYPE=0
GMS_STATS_FILTER_CAMP_TYPE=0

# Hero metadata endpoint
GMS_META_ENDPOINT=2756564
GMS_META_PAGE_SIZE=100

# ── Postgres credentials (used by @mlbb/db connection pool) ──────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=mlbb_tools
